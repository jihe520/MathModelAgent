ENV=dev
# support all model, check out https://docs.litellm.ai/docs/providers
# e.g. gpt-4.1,deepseek/deepseek-chat
# docs/md/tutorial
# 为每个 agent 配置合适的模型 - 使用 Gitee AI (OpenAI 兼容)
COORDINATOR_API_KEY=your_gitee_ai_api_key_here
COORDINATOR_MODEL=DeepSeek-V3
COORDINATOR_BASE_URL=https://ai.gitee.com/v1

# 推荐 thinking model - 使用 Gitee AI (OpenAI 兼容)
MODELER_API_KEY=your_gitee_ai_api_key_here
MODELER_MODEL=DeepSeek-V3
MODELER_BASE_URL=https://ai.gitee.com/v1

CODER_API_KEY=your_gitee_ai_api_key_here
CODER_MODEL=DeepSeek-V3
CODER_BASE_URL=https://ai.gitee.com/v1

WRITER_API_KEY=your_gitee_ai_api_key_here
WRITER_MODEL=DeepSeek-V3
WRITER_BASE_URL=https://ai.gitee.com/v1

# 模型最大问答次数
MAX_CHAT_TURNS=70
# 思考反思次数
MAX_RETRIES=5

# 不需要填，默认调用本地 Python
# E2B_API_KEY=
SERVER_HOST=http://localhost:8000
# 使用 email 注册账号从 https://openalex.org/ 文献
OPENALEX_EMAIL=your_email@example.com

LOG_LEVEL=DEBUG
DEBUG=true
# 确保安装 Redis
# 如果是docker: REDIS_URL=redis://redis:6379/0
# 本地部署 : redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000